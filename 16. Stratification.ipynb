    "N = np.arange(10, 1000)\n",
    "plt.title('Вероятность перекосов')\n",
    "for K in [1.25, 1.5, 2, 3]:\n",
    "    prob = 2 * stats.binom.cdf(N / (1 + K), N, .5)\n",
    "    plt.plot(N, prob, label=f'K= {K}')\n",
    "plt.xscale('log')\n",
    "plt.legend()\n",
    "plt.grid()"
   ]
